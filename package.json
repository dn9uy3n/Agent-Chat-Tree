{
  "name": "agent-chat-tree",
  "displayName": "Agent Chat Tree",
  "description": "Visualize Claude Code AI agent sessions as an interactive tree",
  "version": "0.3.1",
  "publisher": "dn9uy3n",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization", "Other"],
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dn9uy3n/agent-chat-tree.git"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentChatTree",
          "title": "Agent Chat Tree",
          "icon": "media/sidebar.svg"
        }
      ]
    },
    "views": {
      "agentChatTree": [
        {
          "id": "agentChatTreeSidebar",
          "name": "Sessions",
          "icon": "media/sidebar.svg",
          "contextualTitle": "Agent Chat Tree"
        }
      ]
    },
    "commands": [
      {
        "command": "agentChatTree.openPanel",
        "title": "Agent Chat Tree: Open Session Browser",
        "icon": "$(list-tree)"
      },
      {
        "command": "agentChatTree.openSession",
        "title": "Agent Chat Tree: Open Tree View",
        "icon": "$(list-tree)"
      },
      {
        "command": "agentChatTree.resumeSession",
        "title": "Agent Chat Tree: Resume Session in Terminal",
        "icon": "$(debug-start)"
      },
      {
        "command": "agentChatTree.newChildSession",
        "title": "Agent Chat Tree: New Child Session",
        "icon": "$(add)"
      },
      {
        "command": "agentChatTree.deleteSession",
        "title": "Agent Chat Tree: Delete Session",
        "icon": "$(trash)"
      },
      {
        "command": "agentChatTree.refresh",
        "title": "Agent Chat Tree: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "agentChatTree.refreshSidebar",
        "title": "Agent Chat Tree: Refresh Sidebar",
        "icon": "$(refresh)"
      },
      {
        "command": "agentChatTree.search",
        "title": "Agent Chat Tree: Search Prompts",
        "icon": "$(search)"
      },
      {
        "command": "agentChatTree.clearSearch",
        "title": "Agent Chat Tree: Clear Search",
        "icon": "$(close)"
      },
      {
        "command": "agentChatTree.toggleScope",
        "title": "Agent Chat Tree: Toggle Workspace-Only / All Sessions",
        "icon": "$(filter)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "agentChatTree.openPanel"
        },
        {
          "command": "agentChatTree.refresh"
        },
        {
          "command": "agentChatTree.toggleScope"
        },
        {
          "command": "agentChatTree.refreshSidebar"
        },
        {
          "command": "agentChatTree.search"
        },
        {
          "command": "agentChatTree.clearSearch"
        },
        {
          "command": "agentChatTree.resumeSession",
          "when": "false"
        },
        {
          "command": "agentChatTree.openSession",
          "when": "false"
        },
        {
          "command": "agentChatTree.newChildSession",
          "when": "false"
        },
        {
          "command": "agentChatTree.deleteSession",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "agentChatTree.search",
          "when": "view == agentChatTreeSidebar",
          "group": "navigation@0"
        },
        {
          "command": "agentChatTree.clearSearch",
          "when": "view == agentChatTreeSidebar && agentChatTree.searching",
          "group": "navigation@0"
        },
        {
          "command": "agentChatTree.openPanel",
          "when": "view == agentChatTreeSidebar",
          "group": "navigation@1"
        },
        {
          "command": "agentChatTree.toggleScope",
          "when": "view == agentChatTreeSidebar",
          "group": "navigation@2"
        },
        {
          "command": "agentChatTree.refreshSidebar",
          "when": "view == agentChatTreeSidebar",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "agentChatTree.resumeSession",
          "when": "view == agentChatTreeSidebar && viewItem == session",
          "group": "inline@1"
        },
        {
          "command": "agentChatTree.newChildSession",
          "when": "view == agentChatTreeSidebar && viewItem == session",
          "group": "inline@2"
        },
        {
          "command": "agentChatTree.openSession",
          "when": "view == agentChatTreeSidebar && viewItem == session",
          "group": "inline@3"
        },
        {
          "command": "agentChatTree.resumeSession",
          "when": "view == agentChatTreeSidebar && viewItem == session",
          "group": "1_actions@1"
        },
        {
          "command": "agentChatTree.newChildSession",
          "when": "view == agentChatTreeSidebar && viewItem == session",
          "group": "1_actions@2"
        },
        {
          "command": "agentChatTree.openSession",
          "when": "view == agentChatTreeSidebar && viewItem == session",
          "group": "1_actions@3"
        },
        {
          "command": "agentChatTree.deleteSession",
          "when": "view == agentChatTreeSidebar && viewItem == session",
          "group": "9_danger@1"
        }
      ]
    },
    "configuration": {
      "title": "Agent Chat Tree",
      "properties": {
        "agentChatTree.claudeProjectsDir": {
          "type": "string",
          "default": "",
          "description": "Path to ~/.claude/projects directory. Leave empty for auto-detect."
        },
        "agentChatTree.maxSessions": {
          "type": "number",
          "default": 50,
          "description": "Maximum number of recent sessions to show"
        },
        "agentChatTree.workspaceOnly": {
          "type": "boolean",
          "default": true,
          "description": "Show only sessions whose working directory matches the current workspace folder. Disable to list sessions from all projects."
        },
        "agentChatTree.resumeTarget": {
          "type": "string",
          "enum": ["ask", "terminal", "extension"],
          "enumDescriptions": [
            "Ask each time which target to use",
            "Run 'claude --resume' in an integrated terminal",
            "Resume in a Claude Code extension editor tab"
          ],
          "default": "ask",
          "description": "Where to resume a session when clicked: prompt each time, an integrated terminal, or the Claude Code extension."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
